{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://sourcebot-production.up.railway.app/api/$1",
      "headers": {
        "User-Agent": "SourceBot-Vercel"
      }
    },
    {
      "src": "/(?!api/.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://sourcebot-production.up.railway.app"
  }
}
